APP_ENV=dev
DB_PATH=./sentinel.db
RISK_BASELINE_Z=4.0
MIN_ELEVATED_TRIGGERS=3
FORCED_MOVE_GAP_CP=50

# Engine
STOCKFISH_PATH=C:\Users\Accountant\Desktop\Abdul\SentinelAntiCheat\stockfish\stockfish\stockfish-windows-x86-64-avx2.exe
ANALYSIS_DEPTH=22
ANALYSIS_MULTIPV=3
POLYGLOT_BOOK_PATH=
SYZYGY_PATH=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
PERSISTENCE_FAIL_HARD=true

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_PREFIX=sentinel:

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Calibration profile JSON (optional)
CALIBRATION_PROFILE_PATH=C:\Users\Accountant\Desktop\Abdul\SentinelAntiCheat\backend\calibration\regan_calibration_profile.json

# Phase 3 Maia model (optional; fallback heuristic is used when unset/unavailable)
MAIA_MODEL_PATH=
MAIA_MODELS_DIR=
MAIA_LC0_PATH=
MAIA_MODEL_VERSION=maia-v1.0
MAIA_NODES=1
MAIA_THREADS=1
MAIA_BACKEND=blas
MAIA_BACKEND_OPTS=
MAIA_TEMPERATURE=0.0
MAIA_TEMP_DECAY_MOVES=0

# Phase 6 ML fusion (optional; falls back to heuristic when artifacts are absent)
ML_FUSION_ENABLED=true
XGBOOST_MODEL_PATH=
ISOLATION_FOREST_MODEL_PATH=
ML_FUSION_WEIGHT_HEURISTIC=0.4
ML_FUSION_WEIGHT_PRIMARY=0.45
ML_FUSION_WEIGHT_SECONDARY=0.15
ML_FUSION_MIN_MOVES=20

# Phase 8 RBAC / federation scope enforcement
RBAC_ENABLED=true
TENANT_ENFORCEMENT_ENABLED=true
LICHESS_API_TOKEN=lip_pCXrM4h9d2Otih0Qe3n6

# Encryption (base64-url 32-byte key)
SENTINEL_ENCRYPTION_KEY=

# AI report generation
LLM_PROVIDER=none
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=45
REPORT_PDF_ENGINE=auto

# Camera ingestion controls
CAMERA_RAW_STORAGE_ENABLED=false
CONSENT_REQUIRED_FOR_RAW=true
